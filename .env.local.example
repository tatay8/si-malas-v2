# Konfigurasi Supabase untuk SI-MaLas
# Salin file ini menjadi .env.local dan isi nilai-nilainya sesuai dengan proyek Supabase Anda.

# Klien Publik (Bisa diakses dari browser dan server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-Side Saja (HANYA boleh ada di .env.local, JANGAN PERNAH dipublish ke git atau vercel secara publik)
# Digunakan oleh API Route Admin untuk membuat dan me-reset akun wali kelas.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
